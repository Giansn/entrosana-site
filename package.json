{
  "name": "entrosana-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "serve": "node server.mjs",
    "deploy": "astro build && systemctl --user restart entrosana-site",
    "deploy:pages": "astro build && echo 'push to master to publish GitHub Pages (entrosana.com)'"
  },
  "dependencies": {
    "astro": "^5.6.1",
    "sirv": "^3.0.0",
    "@fontsource/geist-mono": "^5.1.0",
    "@fontsource/hanken-grotesk": "^5.1.0",
    "@fontsource/newsreader": "^5.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
