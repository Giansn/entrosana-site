---
const path = Astro.url.pathname;
const links = [
  { href: "/hub", label: "Hub" },
  { href: "/hosted", label: "Hosted" },
  { href: "/hybrid", label: "Hybrid" },
  { href: "/on-premises", label: "On-premises" },
];
const isActive = (href: string) => path === href || path === href + "/";
---
<header class="nav">
  <div class="wrap nav__inner">
    <a href="/" class="brand" aria-label="entrosana — home">
      <span class="brand__mark">E</span><span class="brand__word">entrosana</span>
    </a>
    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class:list={["nav__link", { "is-active": isActive(l.href) }]}>{l.label}</a>
      ))}
    </nav>
    <a href="/hub" class="btn btn--ghost nav__cta">Request access</a>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner { display: flex; align-items: center; gap: 1.5rem; height: 60px; }
  .brand { display: inline-flex; align-items: center; gap: 0.55rem; margin-right: auto; }
  .brand__mark {
    width: 26px; height: 26px; display: grid; place-items: center;
    border: 1px solid var(--ink); border-radius: 50%;
    font-family: var(--font-mono); font-size: 13px; font-weight: 500;
  }
  .brand__word { font-family: var(--font-mono); font-size: 15px; letter-spacing: -0.01em; }
  .nav__links { display: none; gap: 1.4rem; }
  .nav__link {
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.02em;
    color: var(--ink-2); padding-bottom: 2px; border-bottom: 1.5px solid transparent;
  }
  .nav__link:hover { color: var(--ink); }
  .nav__link.is-active { color: var(--ink); border-bottom-color: var(--seal); }
  .nav__cta { display: none; }
  @media (min-width: 760px) {
    .nav__links { display: flex; }
    .nav__cta { display: inline-flex; }
  }
</style>
