---
// Cross-links between the three deployment models.
interface Props { current: "hosted" | "hybrid" | "on-premises"; }
const { current } = Astro.props;
const all = [
  { id: "hosted", href: "/hosted", name: "Hosted", tag: "we run it" },
  { id: "hybrid", href: "/hybrid", name: "Hybrid", tag: "local AI, cloud sync" },
  { id: "on-premises", href: "/on-premises", name: "On-premises", tag: "your hardware" },
];
const others = all.filter((d) => d.id !== current);
---
<section class="section dn">
  <div class="wrap">
    <div class="sealrule"><span class="sig">other ways to run it</span></div>
    <div class="grid grid--2 dn__grid">
      {others.map((d) => (
        <a href={d.href} class="card dn__card">
          <span class="tag">{d.tag}</span>
          <h3>{d.name}</h3>
          <span class="dn__more mono">View →</span>
        </a>
      ))}
    </div>
  </div>
</section>
<style>
  .dn { padding-top: clamp(2rem, 1rem + 3vw, 3.5rem); }
  .dn__grid { margin-top: 1.8rem; }
  .dn__card { display: flex; flex-direction: column; gap: 0.35rem; transition: border-color .15s, transform .1s; }
  .dn__card:hover { border-color: var(--seal); transform: translateY(-2px); }
  .dn__more { color: var(--seal); font-size: var(--step--1); margin-top: 0.4rem; }
</style>
