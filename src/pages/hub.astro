---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SealRule from "../components/SealRule.astro";

const steps = [
  ["Bring the expertise", "You carry the domain — a niche, a population, a method entrosana doesn't cover yet. Propose it as a track."],
  ["We provide the scaffolding", "We pair the proposal with the technical scaffolding: the agent service, the audit plumbing, the deployment pipeline."],
  ["It inherits the guarantees", "The same DLM engine, the same signed audit trail, the same Swiss/EU residency by design apply automatically — not re-implemented per track."],
];

const open = [
  ["Open source", "The full monorepo — agent service, public site, infrastructure config, deployment pipelines. Open under AGPL-3.0."],
  ["Tests as spec", "CI/CD with tests-as-spec. Every deploy is reversible. Open where it makes sense, closed where data residency demands it."],
  ["Shared runway", "Tracks share one cloud runway — no per-partner cloud-cost negotiations, no infrastructure bills passed through to schools or learners."],
];
---
<Layout title="Hub — an open foundation of audit-grade tracks">
  <PageHero
    eyebrow="The open foundation"
    title="Co-create the platform."
    lede="entrosana is a foundation that hosts dedicated tracks — operational tools contributed by aligned practitioners or built in-house. One deterministic engine underneath, many tools on top." />
  <SealRule sig="c2e7a9…f013" />

  <!-- Contribution model -->
  <section class="section">
    <div class="wrap">
      <span class="eyebrow">The contribution model</span>
      <h2 class="display hub__h">Carry a scope we don't cover yet? Propose a track.</h2>
      <div class="grid grid--3 steps">
        {steps.map(([k, v], i) => (
          <div class="card step">
            <span class="step__n mono">{String(i + 1).padStart(2, "0")}</span>
            <h3>{k}</h3>
            <p>{v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open + runway -->
  <section class="section section--ink">
    <div class="wrap">
      <span class="eyebrow">Open by default</span>
      <p class="human hub__lead">Open where it makes sense, closed where data residency demands it.</p>
      <div class="facts">
        {open.map(([k, v]) => (
          <div class="fact"><span class="fact__k">{k}</span><p class="fact__v">{v}</p></div>
        ))}
      </div>
      <p class="hub__src">
        <a href="https://gitlab.com/Giansn/entrosana-ai" class="btn btn--ghost" rel="noopener">View the source · gitlab.com/Giansn/entrosana-ai</a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="wrap split">
      <div>
        <span class="eyebrow">Browse what's built</span>
        <h2 class="display hub__h">See the tools already running on the engine.</h2>
      </div>
      <div>
        <p>The back-office assistant and the learning hub are live tracks today. Each is an operational tool with a clear who-it's-for — and a template for the next one.</p>
        <div class="hub__cta">
          <a href="/tools" class="btn">View tools</a>
          <a href="/learn" class="btn btn--ghost">See the learning track</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hub__h { font-size: var(--step-3); max-width: 18ch; margin-bottom: 2.5rem; }
  .steps { align-items: stretch; }
  .step { display: flex; flex-direction: column; gap: 0.4rem; }
  .step__n { color: var(--seal); font-size: var(--step-1); }
  .step p { color: var(--ink-2); }
  .hub__lead { max-width: 28ch; margin-bottom: 2.5rem; }
  .hub__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.2rem; }
  .hub__src { margin-top: 1.75rem; }
</style>
