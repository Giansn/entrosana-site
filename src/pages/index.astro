---
import Layout from "../layouts/Layout.astro";
import Receipt from "../components/Receipt.astro";
import SealRule from "../components/SealRule.astro";

const deployments = [
  { href: "/hosted", name: "Hosted", tag: "serverless · no idle cost",
    body: "Fastest to start. We run the agent, storage, and integrations. Swiss/EU data residency by design." },
  { href: "/hybrid", name: "Hybrid", tag: "edge-first · data stays put",
    body: "Sensitive documents never leave your premises. A small on-site device handles AI. Structured results sync to the cloud." },
  { href: "/on-premises", name: "On-premises", tag: "your hardware · full stack",
    body: "Same engine, your hardware. For organisations or federations that want the full stack on their own infrastructure." },
];
---
<Layout>
  <!-- Hero: the thesis, proven by a live signed receipt -->
  <section class="section hero">
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <span class="eyebrow">Deterministic Language Models</span>
        <h1 class="display hero__h">Same input.<br />Same output.<br />Every&nbsp;time.</h1>
        <p class="lede">A deterministic, replayable decision path for back-office work — every decision pinned, retrievable, and signed. Built on CashCtrl as the system of record, with Swiss/EU data residency by design.</p>
        <div class="hero__cta">
          <a href="/hub" class="btn">Request access</a>
          <a href="#audit" class="btn btn--ghost">Why deterministic</a>
        </div>
      </div>
      <div class="hero__demo">
        <Receipt />
        <p class="hero__demohint mono muted">Run it. The signature never changes — until you switch to a stochastic model.</p>
      </div>
    </div>
  </section>

  <SealRule sig="a3f1c0…9c2e" />

  <!-- Audit thesis -->
  <section class="section section--ink" id="audit">
    <div class="wrap">
      <span class="eyebrow">The difference</span>
      <p class="human">Stochastic AI agents can't be audited.<br />A DLM is auditable by construction.</p>
      <div class="grid grid--3 pillars">
        <div class="pillar"><span class="pillar__n mono">pinned model version</span><p>The exact model and weights behind every decision are recorded, never silently upgraded.</p></div>
        <div class="pillar"><span class="pillar__n mono">deterministic retrieval order</span><p>The same sources are read in the same order, so the same input resolves the same way.</p></div>
        <div class="pillar"><span class="pillar__n mono">signed audit trail per interaction</span><p>Every answer is anchored to its model version, prompt version, retrieved sources, and reasoning.</p></div>
      </div>
    </div>
  </section>

  <!-- Three pillars: what's built on the engine -->
  <section class="section">
    <div class="wrap">
      <span class="eyebrow">Built on the engine</span>
      <h2 class="display h2 pillars3__h">One deterministic engine. Three ways it shows up.</h2>
      <div class="grid grid--3 pillars3">
        <a href="/tools" class="card pillar3">
          <span class="tag">Tools</span>
          <h3>Back-office work</h3>
          <p>Bookkeeping, payroll, contracts, reconciliation — built to run deterministically on CashCtrl, with the judgement kept with the accountant you already have.</p>
          <span class="pillar3__more mono">View tools →</span>
        </a>
        <a href="/learn" class="card pillar3">
          <span class="tag">Learn</span>
          <h3>A tutor that doesn't drift</h3>
          <p>For learners young and old, academic study, and schools where parents and teachers can audit every answer the AI gave.</p>
          <span class="pillar3__more mono">See learning →</span>
        </a>
        <a href="/hub" class="card pillar3">
          <span class="tag">Hub</span>
          <h3>An open foundation</h3>
          <p>Contribute a dedicated track and inherit the engine, the signed audit trail and Swiss/EU residency by design — open-source, on a shared runway.</p>
          <span class="pillar3__more mono">Explore the hub →</span>
        </a>
      </div>
    </div>
  </section>

  <SealRule sig="7c44ab…0e19" />

  <!-- Deployment -->
  <section class="section" id="deploy">
    <div class="wrap">
      <span class="eyebrow">Three ways to run it</span>
      <h2 class="display h2 deploy__h">Same engine. Same audit trail. Same Swiss/EU residency by design. You choose where it runs.</h2>
      <div class="grid grid--3 deploy">
        {deployments.map((d) => (
          <a href={d.href} class="card deploy__card">
            <span class="tag">{d.tag}</span>
            <h3>{d.name}</h3>
            <p>{d.body}</p>
            <span class="deploy__more mono">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="section section--ink">
    <div class="wrap split">
      <div>
        <span class="eyebrow">Get started</span>
        <h2 class="display h2">Audit-grade AI, on your terms.</h2>
      </div>
      <div>
        <p>Run it hosted in the EU, keep sensitive documents on-premises, or run the full stack yourself. Same engine, same signed audit trail, every way.</p>
        <div class="hero__cta">
          <a href="/hub" class="btn">Request access</a>
          <a href="/#deploy" class="btn btn--ghost">Compare deployment</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero { padding-top: clamp(2.5rem, 1.5rem + 4vw, 5rem); }
  .hero__grid { display: grid; gap: clamp(2rem, 1rem + 5vw, 4rem); align-items: center; }
  @media (min-width: 900px) { .hero__grid { grid-template-columns: 1.05fr 0.95fr; } }
  .hero__h { font-size: var(--step-4); margin: 0.4rem 0 1.4rem; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.8rem; }
  .hero__demo { display: flex; flex-direction: column; gap: 0.9rem; }
  .hero__demohint { font-size: 0.72rem; max-width: 40ch; }

  .h2 { font-size: var(--step-3); max-width: 18ch; }
  .pillars { margin-top: 2.5rem; }
  .pillar__n { display: block; color: #fff; font-size: var(--step-0); margin-bottom: 0.5rem; }
  .pillar__n::before { content: "› "; color: var(--seal); }

  .split { display: grid; gap: clamp(1.5rem, 1rem + 3vw, 3.5rem); }
  @media (min-width: 820px) { .split { grid-template-columns: 1fr 1fr; align-items: start; } }
  .human.small { font-size: var(--step-1); margin-top: 1.2rem; color: var(--ink-2); }
  .section--ink .human.small { color: #C7CBD2; }

  .deploy__h { max-width: 24ch; margin-bottom: 2.5rem; }
  .deploy__card { display: flex; flex-direction: column; gap: 0.5rem; transition: border-color .15s, transform .1s; }
  .deploy__card:hover { border-color: var(--seal); transform: translateY(-2px); }
  .deploy__card p { color: var(--ink-2); flex: 1; }
  .deploy__more { color: var(--seal); font-size: var(--step--1); margin-top: 0.5rem; }

  .pillars3__h { max-width: 20ch; margin-bottom: 2.5rem; }
  .pillars3 { align-items: stretch; }
  .pillar3 { display: flex; flex-direction: column; gap: 0.5rem; transition: border-color .15s, transform .1s; }
  .pillar3:hover { border-color: var(--seal); transform: translateY(-2px); }
  .pillar3 p { color: var(--ink-2); flex: 1; }
  .pillar3__more { color: var(--seal); font-size: var(--step--1); margin-top: 0.5rem; }
</style>
